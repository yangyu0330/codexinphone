{
  "name": "codexinphone",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mobile-first control plane for running Codex CLI on a Windows laptop.",
  "scripts": {
    "dev": "concurrently -k -n server,client -c cyan,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite --host 127.0.0.1",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/server/index.js",
    "codespaces:start": "bash scripts/start-codespaces.sh",
    "codespaces:start:bg": "bash scripts/start-codespaces-background.sh",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "verify:browser": "node scripts/verify-browser.mjs",
    "check:prod-config": "npm run build:server && node scripts/check-production-config.mjs",
    "audit": "npm audit --audit-level=high",
    "ci": "npm run typecheck && npm test && npm run build && npm run audit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "cookie": "^1.0.2",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "lucide-react": "^0.562.0",
    "nanoid": "^5.1.6",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "ws": "^8.18.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/cookie": "^0.6.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "optionalDependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "node-pty": "^1.1.0"
  }
}
