# Server
NODE_ENV=development
HOST=127.0.0.1
PORT=8787
PUBLIC_ORIGIN=http://127.0.0.1:8787
DATA_DIR=.codexinphone
LOG_LEVEL=info
TRUST_PROXY=false

# Auth: github | token | dev
# Use github for real phone access. Use dev only on localhost while developing.
AUTH_MODE=github
SESSION_SECRET=change-this-long-random-value-at-least-32-characters
COOKIE_SECURE=false

# GitHub OAuth app
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://127.0.0.1:8787/auth/github/callback
ALLOWED_EMAILS=your-email@example.com
ALLOWED_GITHUB_LOGINS=your-github-login

# Token mode fallback, not recommended for internet exposure.
PAIRING_TOKEN=

# Production safety limits
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=240
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=12
WS_MAX_MESSAGE_BYTES=65536
WS_MAX_MESSAGES_PER_WINDOW=240
WS_RATE_LIMIT_WINDOW_MS=60000

# Codex CLI
CODEX_COMMAND=codex
CODEX_ARGS=
WORKSPACE_ROOTS=C:\Users\andyw
DEFAULT_CWD=C:\Users\andyw

# AI provider keys are read on the laptop and injected into the local CLI process.
# Leave blank in git. Fill locally after setup.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=
CODEX_MODEL=
