{
  "name": "Codex in Phone",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "forwardPorts": [8787],
  "portsAttributes": {
    "8787": {
      "label": "Codex in Phone",
      "onAutoForward": "notify",
      "visibility": "private"
    }
  },
  "postCreateCommand": "npm ci && npm install -g @openai/codex",
  "customizations": {
    "vscode": {
      "extensions": ["dbaeumer.vscode-eslint"]
    }
  }
}
